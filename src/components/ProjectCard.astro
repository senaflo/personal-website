---
interface Props {
  title: string;
  subtitle?: string;
  image: string;
  href: string;
}

const { title, subtitle, image, href } = Astro.props;
---

<a href={href} class="project-card group block relative overflow-hidden rounded-xl shadow-sm hover:shadow-xl transition-all duration-500">
  <div class="aspect-[4/3] overflow-hidden">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
      loading="lazy"
    />
  </div>
  <!-- Always-visible title bar at bottom -->
  <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-6 pt-16">
    <h3
      class="text-white text-xl font-semibold tracking-tight"
      style="font-family: var(--font-heading);"
    >
      {title}
    </h3>
    {subtitle && (
      <p class="text-white/70 text-sm mt-1">{subtitle}</p>
    )}
  </div>
  <!-- Hover overlay with "View Project" -->
  <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
    <div class="flex items-center gap-2 text-white text-sm font-medium uppercase tracking-wide bg-white/20 backdrop-blur-sm px-5 py-2.5 rounded-full border border-white/30">
      <span>View Project</span>
      <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
      </svg>
    </div>
  </div>
</a>
