---
import Layout from '../layouts/Layout.astro';

const base = '/personal-website';
---

<Layout title="About Me | Sena Flo">
  <!-- Hero / Intro Section -->
  <section class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="fade-in-up">
        <h1
          class="text-5xl md:text-6xl font-semibold tracking-tight"
          style="font-family: var(--font-heading);"
        >
          Hey There
        </h1>
        <p class="mt-8 text-lg md:text-xl leading-relaxed text-gray-600">
          I'm Sena, a Senior majoring in Mechanical Engineering and a minor in Biomedical
          Engineering. I have a passion for product design, particularly in aerospace design and
          medtech. I love to build things and take inspiration from the 6 different countries
          I've lived in!
        </p>
      </div>
      <div class="fade-in-up">
        <div class="overflow-hidden rounded-2xl shadow-lg">
          <img
            src={`${base}/images/about/headshot.jpg`}
            alt="Sena Flo"
            class="w-full h-[400px] md:h-[500px] object-cover hover:scale-105 transition-transform duration-700"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Mosaic Section -->
  <section class="max-w-7xl mx-auto px-6 lg:px-8 pb-24 md:pb-32">
    <div class="fade-in-up text-center max-w-2xl mx-auto mb-16">
      <h2
        class="text-4xl md:text-5xl font-semibold tracking-tight"
        style="font-family: var(--font-heading);"
      >
        All About Me
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-gray-600">
        In my free time I also enjoy hiking, photography, flamenco guitar, and used to fence
        competitively!
      </p>
    </div>

    <!-- Masonry-style Grid -->
    <div class="columns-2 md:columns-3 gap-4 space-y-4 stagger-children">
      <div class="fade-in-up break-inside-avoid">
        <div class="overflow-hidden rounded-xl">
          <img
            src={`${base}/images/about/about-bio.png`}
            alt="About Sena"
            class="w-full h-auto object-cover hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </div>
      <div class="fade-in-up break-inside-avoid">
        <div class="overflow-hidden rounded-xl">
          <img
            src={`${base}/images/about/about-guitar.png`}
            alt="Playing flamenco guitar"
            class="w-full h-auto object-cover hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </div>
      <div class="fade-in-up break-inside-avoid">
        <div class="overflow-hidden rounded-xl">
          <img
            src={`${base}/images/about/about-city.png`}
            alt="City view"
            class="w-full h-auto object-cover hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </div>
      <div class="fade-in-up break-inside-avoid">
        <div class="overflow-hidden rounded-xl">
          <img
            src={`${base}/images/about/about-fencing.png`}
            alt="Fencing"
            class="w-full h-auto object-cover hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </div>
      <div class="fade-in-up break-inside-avoid">
        <div class="overflow-hidden rounded-xl">
          <img
            src={`${base}/images/about/about-nature.png`}
            alt="Nature and hiking"
            class="w-full h-auto object-cover hover:scale-105 transition-transform duration-700"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
