---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const base = '/personal-website';

const projects = [
  {
    title: 'Bellcranks & Dampers',
    subtitle: 'CMR FSAE',
    image: `${base}/images/projects/bellcranks/machined-parts.jpeg`,
    href: `${base}/projects/bellcranks`,
  },
  {
    title: 'Vibration & Tilt Robot',
    subtitle: 'Senior Capstone',
    image: `${base}/images/projects/robot/robot-front.jpg`,
    href: `${base}/projects/robot`,
  },
  {
    title: 'Rear Wing',
    subtitle: 'Aerodynamics Lead',
    image: `${base}/images/projects/rear-wing/car-rear.jpg`,
    href: `${base}/projects/rear-wing`,
  },
  {
    title: "It's Math, Not Rocket Science",
    subtitle: 'Numerical Methods',
    image: `${base}/images/projects/rocket-science/poster.png`,
    href: `${base}/projects/rocket-science`,
  },
  {
    title: 'Steering Lead',
    subtitle: 'CMR FSAE',
    image: `${base}/images/projects/steering/steering-on-car.png`,
    href: `${base}/projects/steering`,
  },
  {
    title: 'Steering',
    subtitle: 'CMR FSAE',
    image: `${base}/images/projects/steering/manufacturing-sparks.jpg`,
    href: `${base}/projects/steering-manufacturing`,
  },
  {
    title: 'Sudoku',
    subtitle: 'Python Game',
    image: `${base}/images/projects/sudoku-thumb.png`,
    href: `${base}/projects/sudoku`,
  },
];
---

<Layout title="Sena Flo | Mechanical Engineering Portfolio">
  <!-- Hero Section -->
  <section class="relative w-full h-[75vh] md:h-[85vh] overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/hero-fsae.jpg`}
        alt="FSAE race car on track"
        class="w-full h-full object-cover"
        style="animation: ken-burns 20s ease-in-out infinite alternate;"
      />
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/30 to-black/10"></div>
    <div class="relative z-10 flex items-end h-full pb-16 md:pb-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <h1
          class="text-4xl md:text-6xl lg:text-7xl font-semibold text-white tracking-tight max-w-3xl leading-tight"
          style="font-family: var(--font-heading);"
        >
          A Short Overview<br /> of My Projects
        </h1>
      </div>
    </div>
  </section>

  <!-- Portfolio Section -->
  <section class="max-w-7xl mx-auto px-6 lg:px-8 py-24 md:py-32">
    <div class="fade-in-up">
      <h2
        class="text-4xl md:text-5xl font-semibold tracking-tight"
        style="font-family: var(--font-heading);"
      >
        My Portfolio
      </h2>
      <p class="mt-6 text-lg md:text-xl leading-relaxed text-gray-600 max-w-3xl">
        Welcome to my collection of experiences! I love to problem-solve and whittle down these
        problems part by part, implementing constraints and design choices until I can finally see
        the whole thing in my hands. I love making my own things, from jewelry to a racecar.
      </p>
    </div>

    <!-- Project Grid -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 stagger-children">
      {projects.map((project) => (
        <div class="fade-in-up">
          <ProjectCard
            title={project.title}
            subtitle={project.subtitle}
            image={project.image}
            href={project.href}
          />
        </div>
      ))}
    </div>
  </section>
</Layout>
