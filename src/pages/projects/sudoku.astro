---
import Layout from '../../layouts/Layout.astro';

const base = '/personal-website';
---

<Layout title="Sudoku | Sena Flo">
  <!-- Title Section (no hero image) -->
  <section class="max-w-5xl mx-auto px-6 lg:px-8 pt-32 md:pt-40 pb-8">
    <h1
      class="text-3xl md:text-5xl font-semibold text-charcoal tracking-tight fade-in-up"
      style="font-family: var(--font-heading);"
    >
      Sudoku
    </h1>
  </section>

  <!-- Description -->
  <section class="max-w-5xl mx-auto px-6 lg:px-8 py-8 md:py-12">
    <div class="fade-in-up">
      <p class="text-lg md:text-xl leading-relaxed text-gray-600 max-w-3xl">
        This was a term project for my CMU 15-112 class. I built 'Killer Sudoku' game using
        Python. Here I built up the game to include hints, legal values, and a 'Killer Mode'.
        This mode is a logic puzzle that combines elements of both Sudoku and Kakuro. It retains
        the core Sudoku rule of placing the digits 1-9 exactly once in each row, column, and
        3&times;3 block. The distinguishing feature is the introduction of 'cages,' which are
        outlined areas containing a sum in the top left corner. The numbers within each cage
        must add up to the given sum, while also adhering to the standard Sudoku rules.
      </p>
    </div>

    <!-- Video Demo -->
    <div class="mt-16 md:mt-24">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Demo</h2>

      <figure class="fade-in-up">
        <div class="overflow-hidden rounded-2xl shadow-md bg-gray-900">
          <video
            src={`${base}/videos/sudoku-demo.mp4`}
            class="w-full h-auto"
            controls
            autoplay
            muted
            loop
            playsinline
          >
            Your browser does not support the video tag.
          </video>
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Killer Sudoku — Gameplay Demo</figcaption>
      </figure>
    </div>

    <!-- Navigation -->
    <div class="mt-20 pt-8 border-t border-gray-200/60">
      <div class="flex items-center justify-between">
        <a
          href={`${base}/projects/steering-manufacturing`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300"
        >
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span class="text-sm font-medium uppercase tracking-wide">Steering MFG</span>
        </a>
        <a
          href={`${base}/projects/rocket-science`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300 ml-auto"
        >
          <span class="text-sm font-medium uppercase tracking-wide">Rocket Science</span>
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
