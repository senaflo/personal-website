---
import Layout from '../../layouts/Layout.astro';

const base = '/personal-website';
---

<Layout title="It's Math, Not Rocket Science | Sena Flo">
  <!-- Title Section (no hero image) -->
  <section class="max-w-5xl mx-auto px-6 lg:px-8 pt-32 md:pt-40 pb-8">
    <h1
      class="text-3xl md:text-5xl font-semibold text-charcoal tracking-tight fade-in-up"
      style="font-family: var(--font-heading);"
    >
      It's Math, Not Rocket Science
    </h1>
  </section>

  <!-- Description -->
  <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 md:py-24">
    <div class="fade-in-up">
      <p class="text-lg md:text-xl leading-relaxed text-gray-600 max-w-3xl">
        Model of Rocket Trajectory using the Runge Kutta Method (4th Order) using Matlab.
      </p>
    </div>

    <!-- Poster -->
    <div class="mt-16">
      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/rocket-science/poster.png`}
            alt="24-311 Numerical Methods Project Poster — It's Math, Not Rocket Science"
            class="w-full h-auto object-contain bg-white"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">24-311 Numerical Methods — Project Poster</figcaption>
      </figure>
    </div>

    <!-- Reference Diagram -->
    <div class="mt-12">
      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md max-w-lg mx-auto">
          <img
            src={`${base}/images/projects/rocket-science/orbital-diagram.png`}
            alt="Orbital Mechanics Coordinate System"
            class="w-full h-auto object-contain bg-white"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">EME 2000 Coordinate System Reference</figcaption>
      </figure>
    </div>

    <!-- Download link -->
    <div class="mt-12 text-center fade-in-up">
      <a
        href={`${base}/RK4_RocketTrajectory.pdf`}
        download
        class="inline-flex items-center gap-2 px-6 py-2.5 bg-charcoal text-cream rounded-full text-sm font-medium tracking-wide uppercase hover:bg-gray-800 transition-colors duration-300"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12M12 16.5V3" />
        </svg>
        Download Full Paper
      </a>
    </div>

    <!-- Navigation -->
    <div class="mt-20 pt-8 border-t border-gray-200/60">
      <div class="flex items-center justify-between">
        <a
          href={`${base}/projects/sudoku`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300"
        >
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span class="text-sm font-medium uppercase tracking-wide">Sudoku</span>
        </a>
        <a
          href={`${base}/projects/robot`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300 ml-auto"
        >
          <span class="text-sm font-medium uppercase tracking-wide">Robot</span>
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
