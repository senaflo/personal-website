---
import Layout from '../../layouts/Layout.astro';

const base = '/personal-website';
---

<Layout title="Steering Lead, Suspension | Sena Flo">
  <!-- Hero Image -->
  <section class="relative w-full h-[55vh] md:h-[70vh] overflow-hidden">
    <img
      src={`${base}/images/projects/steering/steering-on-car.png`}
      alt="Steering system installed on the car"
      class="w-full h-full object-cover"
      style="animation: ken-burns 20s ease forwards;"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16">
      <div class="max-w-5xl mx-auto">
        <h1
          class="text-3xl md:text-5xl font-semibold text-white tracking-tight fade-in-up"
          style="font-family: var(--font-heading);"
        >
          Steering Lead, Suspension
        </h1>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 md:py-24">
    <div class="fade-in-up">
      <p class="text-lg md:text-xl leading-relaxed text-gray-600 max-w-3xl">
        Designed the steering system for the first carbon fiber monocoque chassis, introducing
        new constraints for mounting and tolerancing. Coordinated with powertrain, suspension,
        and driver interface teams. Optimized geometry reducing steering effort by 15%.
        Created Solidworks CAD with clearance studies, performed hand calcs and FEA via ANSYS
        Mechanical. Manufactured and assembled after alumni design reviews.
      </p>
    </div>

    <!-- Gallery: Design -->
    <div class="mt-20">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Design</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/steering/cad-model-color.png`}
              alt="CAD Model — Full Steering Assembly"
              class="w-full h-auto object-contain bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">CAD Model — Full Steering Assembly</figcaption>
        </figure>
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/steering/cad-model-gray.png`}
              alt="Steering Column CAD"
              class="w-full h-auto object-contain bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Steering Column CAD</figcaption>
        </figure>
      </div>
    </div>

    <!-- Gallery: Analysis -->
    <div class="mt-16">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Analysis</h2>

      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/steering/fea-analysis.png`}
            alt="FEA Analysis — Von Mises Stress"
            class="w-full h-auto object-contain bg-gray-50"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">FEA Analysis — Von Mises Stress</figcaption>
      </figure>
    </div>

    <!-- Gallery: Manufacturing -->
    <div class="mt-16">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Manufacturing</h2>

      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/steering/bearing-press.jpg`}
            alt="Bearing Press Assembly"
            class="w-full h-auto object-cover bg-gray-50"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Bearing Press Assembly</figcaption>
      </figure>
    </div>

    <!-- Navigation -->
    <div class="mt-20 pt-8 border-t border-gray-200/60">
      <div class="flex items-center justify-between">
        <a
          href={`${base}/projects/bellcranks`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300"
        >
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span class="text-sm font-medium uppercase tracking-wide">Bellcranks</span>
        </a>
        <a
          href={`${base}/projects/steering-manufacturing`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300 ml-auto"
        >
          <span class="text-sm font-medium uppercase tracking-wide">Steering MFG</span>
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
