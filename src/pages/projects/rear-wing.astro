---
import Layout from '../../layouts/Layout.astro';

const base = '/personal-website';
---

<Layout title="Rear Wing Lead, Aerodynamics | Sena Flo">
  <!-- Hero Image -->
  <section class="relative w-full h-[55vh] md:h-[70vh] overflow-hidden">
    <img
      src={`${base}/images/projects/rear-wing/car-rear.jpg`}
      alt="Car from behind showing the rear wing"
      class="w-full h-full object-cover"
      style="animation: ken-burns 20s ease forwards;"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16">
      <div class="max-w-5xl mx-auto">
        <h1
          class="text-3xl md:text-5xl font-semibold text-white tracking-tight fade-in-up"
          style="font-family: var(--font-heading);"
        >
          Rear Wing Lead, Aerodynamics
        </h1>
      </div>
    </div>
  </section>

  <!-- Description -->
  <section class="max-w-5xl mx-auto px-6 lg:px-8 py-16 md:py-24">
    <div class="fade-in-up">
      <p class="text-lg md:text-xl leading-relaxed text-gray-600 max-w-3xl">
        Designed a multi-element Rear Wing featuring the first ever 3D contoured airfoil element
        to reroute airflow for higher downforce. Conducted CFD analysis using ANSYS Fluent and
        Luminary Cloud. Developed a new manufacturing approach with CNC foam molds and pre-preg
        carbon fiber, vacuum bagged and oven-cured to achieve 3D curvature. Manufactured the
        entire multi-element system.
      </p>
    </div>

    <!-- Gallery: Design -->
    <div class="mt-20">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Design</h2>

      <!-- Full-width: 3-views -->
      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/rear-wing/cad-3views.png`}
            alt="3D CAD Geometry — Multiple Views"
            class="w-full h-auto object-contain bg-gray-50"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">3D CAD Geometry — Multiple Views</figcaption>
      </figure>

      <!-- Side-by-side: side view + mounting -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/rear-wing/cad-side-view.png`}
              alt="Rear Wing CAD — Side Profile"
              class="w-full h-auto object-contain bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Rear Wing CAD — Side Profile</figcaption>
        </figure>
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/rear-wing/cad-mounting.png`}
              alt="Mounting Bracket Design"
              class="w-full h-auto object-contain bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Mounting Bracket Design</figcaption>
        </figure>
      </div>

      <!-- Full-width: assembly -->
      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/rear-wing/cad-assembly.png`}
            alt="Full Assembly Detail"
            class="w-full h-auto object-contain bg-gray-50"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Full Assembly Detail</figcaption>
      </figure>
    </div>

    <!-- Gallery: Analysis -->
    <div class="mt-16">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Analysis</h2>

      <!-- Side-by-side: CFD + airfoil plot -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/rear-wing/cfd-comparison.png`}
              alt="CFD Airflow Comparison — 24e vs 25e"
              class="w-full h-auto object-contain bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">CFD Airflow Comparison — 24e vs 25e</figcaption>
        </figure>
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/rear-wing/airfoil-cp-plot.png`}
              alt="Airfoil Design — Cp vs Chord Length"
              class="w-full h-auto object-contain bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Airfoil Design — Cp vs Chord Length</figcaption>
        </figure>
      </div>
    </div>

    <!-- Gallery: Manufacturing -->
    <div class="mt-16">
      <h2 class="fade-in-up text-sm font-semibold uppercase tracking-widest text-gray-400 mb-10" style="font-family: var(--font-body);">Manufacturing</h2>

      <!-- Side-by-side: kevlar + carbon layup -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/rear-wing/kevlar-layup.jpg`}
              alt="Kevlar Layup on Mold"
              class="w-full h-auto object-cover bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Kevlar Layup on Mold</figcaption>
        </figure>
        <figure class="fade-in-up">
          <div class="overflow-hidden rounded-2xl shadow-md">
            <img
              src={`${base}/images/projects/rear-wing/carbon-fiber-layup.jpg`}
              alt="Carbon Fiber Demolding"
              class="w-full h-auto object-cover bg-gray-50"
              loading="lazy"
            />
          </div>
          <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Carbon Fiber Demolding</figcaption>
        </figure>
      </div>

      <!-- Full-width: carbon molds -->
      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/rear-wing/carbon-molds.png`}
            alt="Carbon Fiber Wing Molds"
            class="w-full h-auto object-contain bg-gray-50"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Carbon Fiber Wing Molds</figcaption>
      </figure>

      <!-- Full-width: team photo -->
      <figure class="fade-in-up mb-8">
        <div class="overflow-hidden rounded-2xl shadow-md">
          <img
            src={`${base}/images/projects/rear-wing/team-with-wing.jpg`}
            alt="Team with Finished Carbon Fiber Wing"
            class="w-full h-auto object-cover bg-gray-50"
            loading="lazy"
          />
        </div>
        <figcaption class="mt-3 text-sm text-gray-500 text-center italic">Team with Finished Carbon Fiber Wing</figcaption>
      </figure>
    </div>

    <!-- Navigation -->
    <div class="mt-20 pt-8 border-t border-gray-200/60">
      <div class="flex items-center justify-between">
        <a
          href={`${base}/projects/robot`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300"
        >
          <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
          <span class="text-sm font-medium uppercase tracking-wide">Robot</span>
        </a>
        <a
          href={`${base}/projects/bellcranks`}
          class="group flex items-center gap-2 text-gray-500 hover:text-charcoal transition-colors duration-300 ml-auto"
        >
          <span class="text-sm font-medium uppercase tracking-wide">Bellcranks</span>
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
